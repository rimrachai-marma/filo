# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Editors & IDEs ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Environment ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND (filo_backend)
# ═══════════════════════════════════════════════════════════════════════════════

filo_backend/node_modules/

# Build output
filo_backend/out/
filo_backend/dist/
filo_backend/*.tgz

# Prisma generated client (regenerated by `bun run db:generate`)
filo_backend/src/generated/prisma/

# File storage (local uploads — not committed)
filo_backend/uploads/
filo_backend/temp_uploads/

# Logs
filo_backend/logs/
filo_backend/*.log
filo_backend/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Test coverage
filo_backend/coverage/
filo_backend/*.lcov

# Caches
filo_backend/.eslintcache
filo_backend/.cache
filo_backend/*.tsbuildinfo

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND (filo_frontend)
# ═══════════════════════════════════════════════════════════════════════════════

filo_frontend/node_modules/

# Next.js build output
filo_frontend/.next/
filo_frontend/out/
filo_frontend/build/

# TypeScript / Next incremental cache
filo_frontend/*.tsbuildinfo
filo_frontend/next-env.d.ts

# Test coverage
filo_frontend/coverage/

# Yarn / pnpm
filo_frontend/.yarn/*
!filo_frontend/.yarn/patches
!filo_frontend/.yarn/plugins
!filo_frontend/.yarn/releases
!filo_frontend/.yarn/versions
filo_frontend/.pnp
filo_frontend/.pnp.*
filo_frontend/.pnpm-debug.log*

# Debug logs
filo_frontend/npm-debug.log*
filo_frontend/yarn-debug.log*
filo_frontend/yarn-error.log*

# Vercel
filo_frontend/.vercel

# ─── Secrets / certificates ───────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
