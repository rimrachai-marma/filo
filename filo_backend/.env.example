# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/filo"

# ─── Server ──────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── CORS (comma-separated origins for production) ───────────
ALLOWED_ORIGINS="http://localhost:3000"

# ─── JWT ─────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_SECRET_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET_EXPIRES_IN="30d"

# ─── File Storage ────────────────────────────────────────────
UPLOAD_DIR="./uploads"
TEMP_UPLOAD_DIR="./temp_uploads"
MAX_FILE_SIZE_BYTES=524288000 // 500 MB

# ─── Email (SMTP) ────────────────────────────────────────────
# Leave blank to use console fallback in development
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@filo.com"

# ─── Cloudflare R2 (S3-compatible) ────────────────────────────
R2_ACCOUNT_ID=
R2_API_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=filo-uploads


# ─── App URL (used in email links) ───────────────────────────
APP_URL="http://localhost:3000"
